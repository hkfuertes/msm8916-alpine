HOST_NAME="uz801a"
USERNAME="user"
PASSWORD="changeme"          # Required — build fails if not set
WIFI_ENABLED="yes"                # Set to "no" to disable WiFi entirely
WIFI_SSID="MyNetwork"
WIFI_PASS="MyPassword"
DTB_FILE="msm8916-yiming-uz801v3.dtb"   # DTB to use in extlinux.conf
USB0_IP="192.168.42.1/24"   # Static IP for USB gadget
                             # Set to "dhcp" when plugged into a router (OpenWrt, etc.)
USB0_GW=""                   # Gateway (e.g. "192.168.42.1") — leave empty for shared/server mode
USB0_DNS=""                  # DNS server (e.g. "8.8.8.8") — leave empty for shared/server mode

# Optional
RELEASE="v3.21"
PMOS_RELEASE="v25.06"
# MIRROR="http://dl-cdn.alpinelinux.org/alpine"
# PMOS_MIRROR="http://mirror.postmarketos.org/postmarketos"

# -- Extra packages (essentials are hardcoded in the script) --
PACKAGES="
chrony
wireguard-tools
wireguard-tools-wg-quick
htop
"

# -- Extra services to auto-start (essentials are hardcoded in the script) --
SERVICES_AUTOSTART="
chronyd
"
